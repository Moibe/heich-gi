# Producción (droplet). Copiar a .env en ~/code/heich-gi y ajustar.
# ORIGIN es clave detrás de nginx: debe ser el dominio final con https.
ORIGIN=https://coleccionador.live
PORT=3300
HOST=127.0.0.1

# SQLite (opcional; default ./local.db relativo al cwd del proceso)
DATABASE_URL=./local.db

# Credenciales del receptor OwnTracks (POST /location y GET /location/history).
# En el droplet las inyecta deploy.yml desde los secrets de GitHub
# OWNTRACKS_USER / OWNTRACKS_PASS. Sin ellas el receptor responde 503.
OWNTRACKS_USER=cambiame
OWNTRACKS_PASS=cambiame
